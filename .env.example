# Provider API Keys (set the ones you have; missing keys = provider disabled)
GEMINI_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPEN_ROUTER_API_KEY=
GITHUB_ACCESS_TOKEN=

# Model overrides (optional — defaults are good)
GEMINI_MODEL=gemini-2.5-flash-lite
NVIDIA_MODEL=mistralai/mistral-nemotron
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=zai-glm-4.7
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
GITHUB_MODEL=openai/gpt-4.1-mini

# Local Ollama (optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=

# Gateway routing order (provider names, comma-separated)
LLM_ORDER=gemini,groq,cerebras,nvidia,openrouter,github

# Which provider each agent prefers (falls back to LLM_ORDER if unavailable)
PLANNER_PROVIDER=gemini
CHECKIN_PROVIDER=groq
GRADER_PROVIDER=groq
FEYNMAN_PROVIDER=groq
VERIFIER_PROVIDER=groq

# Server
PRAXIS_PORT=8099
